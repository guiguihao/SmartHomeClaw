# SmartHomeClaw 环境变量配置
# 复制此文件为 .env 并填入你的配置

# 模型 API Key
NVIDIA_API_KEY=sk-or-v1-your-real-key-here

# 飞书 (Lark) 配置 (可选)
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx

# 百度搜索key 免费 https://console.bce.baidu.com/ai-search/qianfan/ais/console/apiKey
BAIDU_API_KEY=xxxx


# 悠瑞智能家居 MCP 服务器配置
UREAL_TOKEN=xxxx
UREAL_APP_KEY=xxxx
