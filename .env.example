# 环境变量配置模板
# 复制此文件为 .env，填入真实的 API Key

# ============ 模型 API Keys ============
# OpenAI（GPT-4o 等）
OPENAI_API_KEY=sk-your-openai-key-here

# DeepSeek（推荐，性价比高）
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-claude-key-here

#火山引擎
VOLCENGINE_API_KEY=sk-your-volcengine-key-here

# Ollama 本地模型（不需要真实 key，填任意字符串）
OLLAMA_API_KEY=ollama

# ============ 飞书 (Feishu/Lark) ============
FEISHU_APP_ID=your-cli-id-here
FEISHU_APP_SECRET=your-app-secret-here

# ============ 日志级别 ============
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=DEBUG
